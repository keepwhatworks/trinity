{
  "manifest_version": 3,
  "name": "Trinity Local",
  "version": "0.2.22",
  "key": "",
  "description": "Ask all three. Keep what works. Captures conversations from Claude, ChatGPT, and Gemini, and dispatches CLI actions (run council, ingest recent prompts) from the toolbar — all to your local ~/.trinity/ install. No server, no account.",
  "permissions": [
    "nativeMessaging",
    "storage",
    "unlimitedStorage",
    "downloads",
    "tabs",
    "sidePanel"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Trinity — open the side panel",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "popup.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "file:///*",
      "http://localhost/*",
      "http://localhost:*/*",
      "http://127.0.0.1/*",
      "http://127.0.0.1:*/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "content-script.js",
        "sync-pill.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": true
    },
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "adapters/claude.js",
        "adapters/chatgpt.js",
        "adapters/gemini.js",
        "page-hook.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ],
  "minimum_chrome_version": "114",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "sandbox": {
    "pages": [
      "sandbox/launchpad.html",
      "sandbox/live_council.html"
    ]
  }
}
